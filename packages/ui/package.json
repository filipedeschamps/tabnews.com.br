{
  "name": "@tabnews/ui",
  "version": "2.0.0",
  "description": "TabNews UI",
  "license": "MIT",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.js",
    "./document": "./src/_document.jsx",
    "./markdown": "./src/Markdown/index.js",
    "./primer": "./src/primer-react.js",
    "./css": "./src/ui.css"
  },
  "scripts": {
    "test": "vitest --root ../.. watch \"$PWD\"",
    "test:run": "vitest --root ../.. run \"$PWD\"",
    "lint": "eslint . && prettier --check .",
    "format": "eslint --fix . && prettier --write ."
  },
  "dependencies": {
    "@bytemd/plugin-breaks": "^1.22.0",
    "@bytemd/plugin-gemoji": "^1.22.0",
    "@bytemd/plugin-gfm": "^1.22.0",
    "@bytemd/plugin-highlight-ssr": "^1.22.0",
    "@bytemd/plugin-math": "^1.22.0",
    "@bytemd/plugin-mermaid": "^1.22.0",
    "@bytemd/react": "^1.22.0",
    "@primer/octicons-react": "^19.28.0",
    "@primer/react": "^38.26.0",
    "clsx": "^2.1.1",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "peerDependencies": {
    "next": ">=15.2.2",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "author": "TabNews",
  "repository": {
    "type": "git",
    "url": "https://github.com/filipedeschamps/tabnews.com.br",
    "directory": "packages/ui"
  },
  "keywords": [
    "tabnews",
    "ui"
  ]
}
