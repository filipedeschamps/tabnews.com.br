{
  "name": "@tabnews/config",
  "version": "2.0.0",
  "description": "Configurações padronizadas dos projetos TabNews",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    "./eslint": "./src/shared/eslint.config.cjs",
    "./lint-staged": "./src/shared/lint-staged.cjs",
    "./package.json": "./package.json",
    "./prettier": "./src/shared/prettier.config.cjs",
    "./vitest": "./src/shared/vitest.config.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest --root ../.. watch --passWithNoTests \"$PWD\"",
    "test:run": "vitest --root ../.. run --passWithNoTests \"$PWD\"",
    "lint": "eslint . --max-warnings 0 && prettier --check .",
    "format": "eslint --fix . && prettier --write ."
  },
  "dependencies": {
    "@eslint/js": "9.39.4",
    "@next/eslint-plugin-next": "16.2.6",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/eslint-plugin": "1.6.18",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-primer-react": "8.6.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "typescript-eslint": "8.60.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.7"
  },
  "author": "Turma do TabNews",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/filipedeschamps/tabnews.com.br.git",
    "directory": "packages/config"
  },
  "keywords": [
    "config",
    "tabnews"
  ]
}
